<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  TestNG Suite Configuration

  HOW TO RUN:
    All tests:       mvn test
    Override browser: mvn test -Dbrowser=firefox
    Headless CI:      mvn test -Dheadless=true

  Browser is no longer passed as a <parameter> here.
  It is resolved by ConfigReader in this order:
    1. -Dbrowser=xxx  (Maven/CLI system property)
    2. browser=       in config.properties
    3. Default        "chrome"

  parallel="none" — tests run sequentially.
  Required for the E2E checkout flow where each step depends on the previous one.
-->
<suite name="UI Automation Suite" verbose="1" parallel="none">

    <!-- TestListener logs test events to ExtentReport and Log4j2 -->
    <listeners>
        <listener class-name="com.automation.listeners.TestListener"/>
    </listeners>

    <test name="Checkout Flow">
        <classes>
            <class name="com.automation.tests.CheckoutFlowTest"/>
        </classes>
    </test>

</suite>
